CREATE TABLE Trips (
    TripID INT PRIMARY KEY AUTO_INCREMENT,
    BusID INT,
    StartLocation VARCHAR(100),
    EndLocation VARCHAR(100),
    Fare DECIMAL(10,2),
    TripDate DATE,
    FOREIGN KEY (BusID) REFERENCES Buses(BusID)
);  -- ← semicolon was missing here

